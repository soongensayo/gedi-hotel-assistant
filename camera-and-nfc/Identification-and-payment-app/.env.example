# Copy to .env and fill in values. Do not commit .env.

# --- Supabase (required for server sync) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Optional: for write/update operations
SUPABASE_SERVICE_ROLE_KEY=

# --- Camera ---
# Camera index: 0 = default, 1 = first USB, etc. Set in .env if external camera not detected.
# CAMERA_INDEX=0

# --- EasyOCR (optional; for edge/offline) ---
# Path to folder containing craft_mlt_25k.pth and english_g2.pth.
# If unset, the app uses ./easyocr_models/ if present, else EasyOCR default (may download on first run).
# EASYOCR_MODULE_PATH=./easyocr_models
# Set to 1 to disable EasyOCR and use Tesseract-only (limited).
# DISABLE_EASYOCR=0

# --- NFC (optional) ---
# Serial port for ESP32 NFC reader. Default: COM3 (Windows), /dev/ttyUSB0 (Linux).
# NFC_SERIAL_PORT=COM3

# --- OCR timing & debug (optional) ---
# Set to true/1 to log OCR step durations (e.g. in run_test_image.py); false = no timing logs. Master switch.
# OCR_TIMING=false
# Set to true to save debug images to debug/variants/; false = none.
# DEBUG_ACTIVATE=false
