# =============================================================================
# AI Hotel Check-in Kiosk - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# -----------------------------------------------------------------------------
# OpenAI API (Chat, TTS, STT) — used by backend
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here

# -----------------------------------------------------------------------------
# Google Gemini API (Fallback LLM) — used by backend
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here

# -----------------------------------------------------------------------------
# Simli Avatar (Frontend WebRTC) — VITE_ prefix exposes to frontend
# -----------------------------------------------------------------------------
VITE_SIMLI_API_KEY=your-simli-api-key-here
VITE_SIMLI_FACE_ID=your-simli-face-id-here

# Also keep backend copies for any server-side avatar operations
SIMLI_API_KEY=your-simli-api-key-here
SIMLI_FACE_ID=your-simli-face-id-here

# D-ID (alternative avatar, backend-only)
DID_API_KEY=your-did-api-key-here

# -----------------------------------------------------------------------------
# Supabase (Hotel Data Backend)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Frontend Supabase access (read-only)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# -----------------------------------------------------------------------------
# Apple Wallet (Digital Key Card)
# -----------------------------------------------------------------------------
APPLE_PASS_TYPE_ID=
APPLE_TEAM_ID=
APPLE_PASS_P12_PATH=./backend/certs/Certificates.p12
APPLE_PASS_P12_PASSWORD=
APPLE_WWDR_CERT_PATH=./backend/certs/AppleWWDRCAG4.pem

# -----------------------------------------------------------------------------
# Email (SMTP) — Gmail: use App Password from https://myaccount.google.com/apppasswords
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=gedihotel@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="The Grand Azure Hotel <gedihotel@gmail.com>"

# -----------------------------------------------------------------------------
# Application Config
# -----------------------------------------------------------------------------
BACKEND_PORT=3001
FRONTEND_PORT=5173
HARDWARE_MODE=mock
AI_PROVIDER=openai
AVATAR_PROVIDER=simli
TTS_VOICE=nova
HOTEL_NAME=The Grand Azure Hotel

# -----------------------------------------------------------------------------
# Passport Scanner — set to "live" to use the real camera + OCR pipeline
# -----------------------------------------------------------------------------
PASSPORT_SCANNER_MODE=mock
# PASSPORT_SCANNER_PYTHON=python3
# PASSPORT_SCANNER_TIMEOUT=60000

# -----------------------------------------------------------------------------
# NFC Card Reader (ESP32 + PN532)
# -----------------------------------------------------------------------------
# Mode: "serial" (default) = ESP32 connected via USB, reads serial port directly
#        "wifi"  (legacy)  = ESP32 on WiFi, encrypted ACTIVATE/UID handshake
NFC_MODE=serial
# Serial port for the ESP32 USB connection (only used when NFC_MODE=serial)
# Mac: /dev/cu.usbserial-* or /dev/cu.SLAB_USBtoUART
# Linux/Jetson: /dev/ttyUSB0
NFC_SERIAL_PORT=/dev/ttyUSB0
# NFC_SERIAL_BAUD=115200
# Map NFC UIDs to card last-4 digits for display
# NFC_UID_TO_LAST4={"09C9C802":"5264"}
# Legacy WiFi mode settings (only used when NFC_MODE=wifi)
# NFC_SHARED_SECRET_KEY=
# ESP32_WIFI_START_URL=
